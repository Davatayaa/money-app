#SERVER PORT
APP_PORT=:8080

#DATABASE CONFIG
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

#DIRECTORY PICTURES
STORAGE_PATH=your_storage_pictures_path

# GEMINI API 5 KEY
GEMINI_API_KEYS="your_gemini_api_key_1,your_gemini_api_key_2,your_gemini_api_key_3,your_gemini_api_key_4,your_gemini_api_key_5"

#FRONTEND URL
FRONTEND_URL=http://localhost:5173

# URL BACKEND
BACKEND_URL=http://localhost:8080

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
